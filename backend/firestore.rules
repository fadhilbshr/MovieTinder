rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /sessions/{sessionId} {
      // Session metadata (filters, movieIds, status) is only ever written
      // server-side, by the generateSessionList Cloud Function using the
      // Admin SDK — which bypasses these rules entirely.
      allow read: if request.auth != null;
      allow write: if false;

      match /participants/{participantId} {
        allow read: if request.auth != null;

        // A participant can only ever create their own doc, must join as
        // 'joined' (not ready), and can only join while the session is
        // still in its lobby — once startSwiping has flipped the session to
        // 'active', no new participants can be added.
        allow create: if request.auth != null
                      && request.auth.uid == participantId
                      && request.resource.data.status == 'joined'
                      && get(/databases/$(database)/documents/sessions/$(sessionId)).data.status == 'lobby';

        // A participant can only update their own doc, and only along two
        // paths:
        //  - toggle ready state back and forth while still in the lobby
        //    ('joined' <-> 'ready')
        //  - once swiping has started, move from 'active' to 'finished' or
        //    'left'
        // The 'ready' -> 'active' transition is never written by a client —
        // only the startSwiping Cloud Function (Admin SDK) makes it, once
        // every participant is ready. Once 'left', a doc is locked — no
        // rejoining (see spec §7, "rejoining after leaving").
        allow update: if request.auth != null
                      && request.auth.uid == participantId
                      && (
                           (resource.data.status in ['joined', 'ready']
                             && request.resource.data.status in ['joined', 'ready'])
                           || (resource.data.status == 'active'
                             && request.resource.data.status in ['finished', 'left'])
                         );

        // Leaving during the lobby (before swiping starts) just removes the
        // participant doc outright — they never had a deck position, so
        // there's nothing to auto-swipe. Leaving mid-swipe instead uses the
        // update path above ('active' -> 'left'), which onParticipantLeave
        // reacts to.
        allow delete: if request.auth != null
                      && request.auth.uid == participantId
                      && resource.data.status in ['joined', 'ready'];
      }

      match /swipes/{swipeId} {
        // swipeId convention: {participantId}_{movieId}
        allow read: if request.auth != null;

        // Clients may only ever record genuine swipes. 'auto_left' swipes
        // are written exclusively by the onParticipantLeave Cloud Function
        // via the Admin SDK, never by a client.
        allow create: if request.auth != null
                      && request.resource.data.participantId == request.auth.uid
                      && request.resource.data.direction in ['left', 'right']
                      && request.resource.data.source == 'swipe';

        // Swipes are immutable once cast.
        allow update: if false;
        allow delete: if false;
      }

      match /movieStats/{movieId} {
        // Fully derived data. Only onSwipeWrite / onParticipantLeave
        // Cloud Functions write here.
        allow read: if request.auth != null;
        allow write: if false;
      }
    }
  }
}
