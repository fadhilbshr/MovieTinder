<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".MovieSwipeApp"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:theme="@style/Theme.MovieSwipe"
        android:supportsRtl="true">

        <!-- Join-link App Link intent-filter (android:autoVerify, https scheme,
             assetlinks.json-backed domain) lands in Phase 3 alongside the rest
             of the join flow, once Phase 0's domain/Hosting setup exists. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.MovieSwipe">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
